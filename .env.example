# Coddy Configuration
# Copy this file to .env and update the values

# =============================================================================
# LLM Configuration
# =============================================================================

# Base URL for the LLM API (OpenAI-compatible)
# Examples:
#   - Ollama: http://localhost:11434/v1
#   - vLLM: http://localhost:8000/v1
LLM_BASE_URL=http://localhost:11434/v1

# Model name
# Examples: qwen3-coder, llama3, mistral, gpt-4
LLM_MODEL=qwen3-coder

# API key (leave empty for local models like Ollama)
LLM_API_KEY=

# =============================================================================
# Sandbox Configuration
# =============================================================================

# Sandbox type: subprocess | docker
# WARNING: subprocess runs code directly on your machine - NOT secure!
SANDBOX_TYPE=subprocess

# Docker image (only used when SANDBOX_TYPE=docker)
SANDBOX_IMAGE=coddy-sandbox:latest

# Default execution timeout in seconds (max: 120)
SANDBOX_TIMEOUT=30

# Memory limit for sandbox containers
SANDBOX_MEMORY_LIMIT=512m

# CPU limit (number of cores)
SANDBOX_CPU_LIMIT=1

# Network mode: none | bridge
# Use "none" for maximum security
SANDBOX_NETWORK=none

# =============================================================================
# Orchestrator Configuration
# =============================================================================

# Maximum consecutive tool calls per message
MAX_TOOL_ITERATIONS=10

# Session timeout in seconds
SESSION_TIMEOUT=3600

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind the server to
HOST=0.0.0.0

# Port to run the server on
PORT=8000

# Log level: debug | info | warning | error
LOG_LEVEL=info
