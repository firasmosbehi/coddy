# Coddy Configuration
# Copy this file to .env and update the values

# =============================================================================
# LLM Configuration
# =============================================================================

# Base URL for the LLM API (OpenAI-compatible)
# Examples:
#   - Ollama: http://localhost:11434/v1
#   - vLLM: http://localhost:8000/v1
#   - Together AI: https://api.together.xyz/v1
#   - OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=http://localhost:11434/v1

# Model name to use
# Examples:
#   - Ollama: qwen3-coder, llama3, mistral
#   - Together AI: meta-llama/Llama-3-70b-chat-hf
#   - OpenAI: gpt-4, gpt-3.5-turbo
LLM_MODEL=qwen3-coder

# API key for the LLM provider (leave empty for local models like Ollama)
LLM_API_KEY=

# =============================================================================
# Sandbox Configuration
# =============================================================================

# Sandbox type: subprocess | docker | e2b
# WARNING: subprocess is NOT secure and should only be used for development
SANDBOX_TYPE=docker

# Docker image to use for the sandbox (only used when SANDBOX_TYPE=docker)
SANDBOX_IMAGE=coddy-sandbox:latest

# Default execution timeout in seconds (max: 120)
SANDBOX_TIMEOUT=30

# Memory limit for sandbox containers (e.g., 512m, 1g)
SANDBOX_MEMORY_LIMIT=512m

# CPU limit for sandbox containers (number of cores)
SANDBOX_CPU_LIMIT=1

# Network mode for sandbox: none | bridge
# Use "none" for maximum security (no internet access)
# Use "bridge" if you need network access (e.g., for pip install)
SANDBOX_NETWORK=none

# =============================================================================
# Orchestrator Configuration
# =============================================================================

# Maximum number of consecutive tool calls per user message
MAX_TOOL_ITERATIONS=10

# Session timeout in seconds (session destroyed after inactivity)
SESSION_TIMEOUT=3600

# =============================================================================
# Server Configuration (for API mode)
# =============================================================================

# Host to bind the server to
HOST=0.0.0.0

# Port to run the server on
PORT=8000

# Log level: debug | info | warning | error
LOG_LEVEL=info

# =============================================================================
# E2B Configuration (optional, only if using E2B sandbox)
# =============================================================================

# E2B API key (get from https://e2b.dev)
E2B_API_KEY=
